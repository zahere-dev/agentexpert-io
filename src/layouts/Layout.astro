---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Roadmaps, patterns, tips and case studies for building AI agents." } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | agentexpert.io</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <header>
    <div class="container header-inner">
      <a href="/" class="logo">agentexpert.io</a>
      <nav>
        <a href="/roadmaps">Roadmaps</a>
        <a href="/patterns">Patterns</a>
        <a href="/tips">Tips</a>
        <a href="/case-studies">Case studies</a>
        <a href="/about">About</a>
      </nav>
    </div>
  </header>
  <main><slot /></main>
  <footer>
    <div class="container footer-inner">
      <span>Built by <a href="/about">Zahiruddin Tavargere</a></span>
      <div class="footer-links">
        <a href="https://youtube.com/@adaptiveengineer" target="_blank">YouTube</a>
        <a href="https://newsletter.adaptiveengineer.com" target="_blank">Newsletter</a>
        <a href="https://twitter.com/zahiruddin_t" target="_blank">Twitter</a>
        <a href="https://zahere.com" target="_blank">Blog</a>
      </div>
    </div>
  </footer>
</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #ffffff;
    --text: #111111;
    --muted: #6b7280;
    --border: #e5e7eb;
    --surface: #f9fafb;
    --accent: #111111;
    --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }
  html { font-size: 16px; -webkit-font-smoothing: antialiased; }
  body { font-family: var(--font); background: var(--bg); color: var(--text); min-height: 100vh; display: flex; flex-direction: column; line-height: 1.6; }
  a { color: inherit; text-decoration: none; }
  .container { max-width: 760px; margin: 0 auto; padding: 0 1.5rem; }

  header { border-bottom: 1px solid var(--border); padding: 1rem 0; }
  .header-inner { display: flex; align-items: center; justify-content: space-between; }
  .logo { font-size: 0.95rem; font-weight: 600; color: var(--text); }
  nav { display: flex; gap: 1.75rem; }
  nav a { font-size: 0.875rem; color: var(--muted); transition: color 0.15s; }
  nav a:hover { color: var(--text); }

  main { flex: 1; }

  footer { border-top: 1px solid var(--border); padding: 1.5rem 0; margin-top: 5rem; }
  .footer-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.75rem; }
  footer span, footer a { font-size: 0.8rem; color: var(--muted); }
  footer a:hover { color: var(--text); }
  .footer-links { display: flex; gap: 1.25rem; }

  .tag { display: inline-block; font-size: 0.72rem; font-weight: 500; padding: 0.2rem 0.55rem; border: 1px solid var(--border); border-radius: 4px; color: var(--muted); background: var(--surface); }
  .label-beginner { color: #16a34a; border-color: #bbf7d0; background: #f0fdf4; }
  .label-intermediate { color: #d97706; border-color: #fde68a; background: #fffbeb; }
  .label-advanced { color: #dc2626; border-color: #fecaca; background: #fef2f2; }

  .prose h2 { font-size: 1.15rem; font-weight: 600; margin: 2.5rem 0 0.75rem; }
  .prose h3 { font-size: 1rem; font-weight: 600; margin: 2rem 0 0.5rem; }
  .prose p { color: var(--muted); margin-bottom: 1rem; font-size: 0.925rem; }
  .prose ul, .prose ol { padding-left: 1.25rem; margin-bottom: 1rem; }
  .prose li { color: var(--muted); font-size: 0.925rem; margin-bottom: 0.35rem; }
  .prose code { font-family: 'SF Mono', 'Fira Code', monospace; font-size: 0.82em; background: var(--surface); border: 1px solid var(--border); padding: 0.1em 0.35em; border-radius: 3px; }
  .prose pre { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 1.25rem; overflow-x: auto; margin-bottom: 1.5rem; }
  .prose pre code { background: none; border: none; padding: 0; font-size: 0.85rem; }
  .prose strong { color: var(--text); font-weight: 600; }
  blockquote { border-left: 3px solid var(--border); padding-left: 1rem; margin: 1.5rem 0; }
  blockquote p { font-style: italic; }
</style>
