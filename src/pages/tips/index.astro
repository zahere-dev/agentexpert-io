---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Tips & Tricks" description="Bite-sized AI agent tips from real-world deployments.">
  <div class="container">
    <div class="section-header">
      <h1>💡 Tips & Tricks</h1>
      <p>Bite-sized, battle-tested insights from building AI agents at scale. No fluff — just things that actually matter.</p>
    </div>
    <div class="coming-soon">
      <p>📝 Tips are being added. <a href="https://newsletter.adaptiveengineer.com" target="_blank">Subscribe to the newsletter</a> to get notified when new tips drop.</p>
    </div>
  </div>
</Layout>
<style>
  .coming-soon { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 3rem; text-align: center; color: var(--muted); margin-top: 2rem; }
  .coming-soon a { color: var(--accent); }
</style>
