---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Tips & Tricks" description="Bite-sized AI agent tips.">
  <div class="container">
    <section class="page-header">
      <h1>Tips & tricks</h1>
      <p>Bite-sized, battle-tested insights from building AI agents at scale.</p>
    </section>
    <p class="cta-note">Tips coming soon. Subscribe to <a href="https://newsletter.adaptiveengineer.com" target="_blank">The Adaptive Engineer</a> to get notified.</p>
  </div>
</Layout>
<style>
  .page-header { padding: 4rem 0 2.5rem; border-bottom: 1px solid var(--border); margin-bottom: 2rem; }
  .page-header h1 { font-size: 1.5rem; font-weight: 600; margin-bottom: 0.5rem; }
  .page-header p { font-size: 0.9rem; color: var(--muted); }
  .cta-note { font-size: 0.82rem; color: var(--muted); }
  .cta-note a { border-bottom: 1px solid var(--border); color: var(--text); }
</style>
