---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Case Studies" description="Real AI agent implementations — problem, architecture, and learnings.">
  <div class="container">
    <div class="section-header">
      <h1>📚 Case Studies</h1>
      <p>Real-world agent implementations broken down: problem → architecture → results → honest learnings.</p>
    </div>
    <div class="coming-soon">
      <p>📝 Case studies are being added. <a href="https://newsletter.adaptiveengineer.com" target="_blank">Subscribe to the newsletter</a> to get notified.</p>
    </div>
  </div>
</Layout>
<style>
  .coming-soon { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 3rem; text-align: center; color: var(--muted); margin-top: 2rem; }
  .coming-soon a { color: var(--accent); }
</style>
