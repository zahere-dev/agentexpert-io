---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Case Studies" description="Real AI agent implementations, broken down.">
  <div class="container">
    <section class="page-header">
      <h1>Case studies</h1>
      <p>Real-world implementations: problem → architecture → results → honest learnings.</p>
    </section>
    <p class="cta-note">Case studies coming soon. Subscribe to <a href="https://newsletter.adaptiveengineer.com" target="_blank">The Adaptive Engineer</a> to get notified.</p>
  </div>
</Layout>
<style>
  .page-header { padding: 4rem 0 2.5rem; border-bottom: 1px solid var(--border); margin-bottom: 2rem; }
  .page-header h1 { font-size: 1.5rem; font-weight: 600; margin-bottom: 0.5rem; }
  .page-header p { font-size: 0.9rem; color: var(--muted); }
  .cta-note { font-size: 0.82rem; color: var(--muted); }
  .cta-note a { border-bottom: 1px solid var(--border); color: var(--text); }
</style>
