---
import Layout from '../../layouts/Layout.astro';
const roadmaps = [
  { slug: 'zero-to-ai-agent', title: 'Zero to AI agent', desc: 'Understand what agents are, how LLMs reason, and build your first functional agent from scratch.', level: 'beginner', tags: ['LLMs', 'Tools', 'LangChain'] },
  { slug: 'se-to-ai-engineer', title: 'Software engineer → AI engineer', desc: "Leverage your existing SE skills. A 3-month path based on Zahere's own transition at Dell.", level: 'intermediate', tags: ['GenAI', 'MLOps', 'System design'] },
  { slug: 'production-agents', title: 'Production-grade agents', desc: 'Move beyond prototypes. Observability, reliability, human-in-the-loop, and scale.', level: 'advanced', tags: ['LangGraph', 'Observability', 'Scale'] },
  { slug: 'agentic-rag', title: 'Agentic RAG mastery', desc: 'Go beyond naive RAG. Build agents that retrieve, reason, and synthesize intelligently.', level: 'intermediate', tags: ['RAG', 'Vector DBs', 'Retrieval'] },
];
---
<Layout title="Roadmaps" description="Structured AI agent learning paths.">
  <div class="container">
    <section class="page-header">
      <h1>Roadmaps</h1>
      <p>Structured learning paths — so you always know what to study next.</p>
    </section>
    <div class="list">
      {roadmaps.map(r => (
        <a href={`/roadmaps/${r.slug}`} class="list-item">
          <div class="list-item-main">
            <p class="list-title">{r.title}</p>
            <p class="list-desc">{r.desc}</p>
            <div class="list-tags">
              <span class={`tag label-${r.level}`}>{r.level}</span>
              {r.tags.map(t => <span class="tag">{t}</span>)}
            </div>
          </div>
          <span class="arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .page-header { padding: 4rem 0 2.5rem; border-bottom: 1px solid var(--border); margin-bottom: 2rem; }
  .page-header h1 { font-size: 1.5rem; font-weight: 600; margin-bottom: 0.5rem; }
  .page-header p { font-size: 0.9rem; color: var(--muted); }
  .list { display: flex; flex-direction: column; }
  .list-item { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; padding: 1.5rem 0; border-bottom: 1px solid var(--border); transition: opacity 0.15s; }
  .list-item:hover .list-title { text-decoration: underline; }
  .list-item-main { flex: 1; }
  .list-title { font-size: 0.95rem; font-weight: 500; margin-bottom: 0.35rem; }
  .list-desc { font-size: 0.85rem; color: var(--muted); margin-bottom: 0.75rem; line-height: 1.5; }
  .list-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .arrow { color: var(--muted); font-size: 0.9rem; flex-shrink: 0; margin-top: 0.1rem; }
</style>
